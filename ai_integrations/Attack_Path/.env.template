# ThreatModeler Configuration
# Get your API key from ThreatModeler platform settings
THREATMODELER_API_URL=https://your-instance.threatmodeler.com
THREATMODELER_API_KEY=your_api_key_here

# OpenAI Configuration
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7

# MITRE ATT&CK Configuration
MITRE_STIX_URL=https://raw.githubusercontent.com/mitre/cti/master/enterprise-attack/enterprise-attack.json
MITRE_CACHE_DIR=./cache/mitre
MITRE_CACHE_EXPIRY_DAYS=7

# Application Configuration
LOG_LEVEL=INFO
OUTPUT_DIR=./output
MAX_ATTACK_PATHS_PER_THREAT=3
MIN_LIKELIHOOD_SCORE=5

# Parallel Processing Configuration
# MAX_WORKERS: Number of concurrent OpenAI API calls (default: 8)
# Adjust based on your OpenAI rate limits and performance needs
MAX_WORKERS=8

# MAX_THREATS_TO_PROCESS: Limit number of threats to process (0 = process all)
# Set to a positive number for testing or to limit processing
MAX_THREATS_TO_PROCESS=0

# Optional: Proxy Configuration (if needed)
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=https://proxy.example.com:8080
